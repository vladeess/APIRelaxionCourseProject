rem start в— это команда Windows командной строки (cmd.exe), 
rem предназначенная для запуска указанной программы, 
rem команды или открытия файла/папки в отдельном новом окне.
rem В отличие от прямого вызова программы, start позволяет 
rem скрипту продолжить выполнение, не дожидаясь закрытия запущенного приложения.
start C:\visual\APIRelaxion\OperateNode\bin\Debug\OperateNode.exe 1
start C:\visual\APIRelaxion\OperateNode\bin\Debug\OperateNode.exe 2

